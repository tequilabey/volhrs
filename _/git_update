#!/bin/bash
set -euo pipefail

APPID="volhrs"
APPCD="vh"
APPDIR="/opt/lodge/$APPID"

echo "=== Git update: $APPID ==="
cd "$APPDIR"

if [ ! -d .git ]; then
  echo "ERROR: $APPDIR is not a git repository"
  exit 1
fi

BACKUP_DIR="$(mktemp -d /tmp/${APPCD}_backup.XXXXXX)"
trap 'rm -rf "$BACKUP_DIR"' EXIT

echo "Backing up local files..."
[ -f .env ] && cp .env "$BACKUP_DIR/.env"

echo "Resetting repo..."
git reset --hard
git clean -fdx
git pull

echo "Restoring local files..."
[ -f "$BACKUP_DIR/.env" ] && cp "$BACKUP_DIR/.env" .env

echo "Git update complete."
