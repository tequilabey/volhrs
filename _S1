#!/bin/bash
#  chmod uy+x _S1
#
cd ~/apps/volhrs

# stop the service so nothing is holding old code in memory
sudo systemctl stop volhrs

# clean & rebuild (removes stale build artifacts)
rm -rf build .svelte-kit
npm run build

# start again
sudo systemctl start volhrs

# watch logs and then try one save
sudo journalctl -f -u volhrs
